   "source": [
    "import os\n",
    "\n",
    "old_name = \"QFast\"\n",
    "\n",
    "for i in range(7):\n",
    "    filt = 2**i\n",
    "    name = old_name + f\"_{filt}\" + \".h5\"\n",
    "    newName = f\"QSmall_{filt}.h5\"\n",
    "    os.rename(name, newName)\n",
    "\n",
    "print(\"File renamed.\")"
   ]
